      "id": "get-meta-creds",
      "name": "GET Meta Credentials",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 200],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const creds = $input.first().json;\nconst queueItem = $('Tem Fila?').first().json;\n\nconst integration = Array.isArray(creds) ? creds[0] : creds;\n\nif (!integration || !integration.meta_graph_token || !integration.instagram_page_id) {\n  return [{ json: { skip: true, queue_id: queueItem.id, reason: 'no_meta_creds' } }];\n}\n\nconst carousel = queueItem.carousels;\nconst slides = typeof carousel.slides_json === 'string' \n  ? JSON.parse(carousel.slides_json) \n  : carousel.slides_json;\n\nconst caption = carousel.caption || '';\nconst hashtags = carousel.hashtags || '';\nconst fullCaption = `${caption}\\n\\n${hashtags}`.trim();\n\nreturn [{\n  json: {\n    skip: false,\n    queue_id: queueItem.id,\n    carousel_id: carousel.id,\n    tenant_id: carousel.tenant_id,\n    access_token: integration.meta_graph_token,\n    ig_user_id: integration.instagram_page_id,\n    slides: slides,\n    caption: fullCaption,\n    slide_count: slides.length\n  }\n}];"
      },
      "id": "prepare-publish",
      "name": "Preparar Publicacao",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "creds-ok",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notTrue"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-creds-ok",
      "name": "Credenciais OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1780, 200]
    },
    {
      "parameters": {
        "jsCode": "// Upload each slide to Meta Graph API as media container\nconst data = $input.first().json;\nconst slides = data.slides;\nconst accessToken = data.access_token;\nconst igUserId = data.ig_user_id;\n\nconst containerIds = [];\n\nfor (let i = 0; i < slides.length; i++) {\n  const slide = slides[i];\n  const imageUrl = slide.image_url || slide.url || slide.src;\n  \n  if (!imageUrl) continue;\n\n  const response = await fetch(\n    `https://graph.facebook.com/v19.0/${igUserId}/media`,\n    {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        image_url: imageUrl,\n        is_carousel_item: true,\n        access_token: accessToken\n      })\n    }\n  );\n  \n  const result = await response.json();\n  if (result.id) {\n    containerIds.push(result.id);\n  }\n}\n\n// Create carousel container\nconst carouselResponse = await fetch(\n  `https://graph.facebook.com/v19.0/${igUserId}/media`,\n  {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({\n      media_type: 'CAROUSEL',\n      children: containerIds.join(','),\n      caption: data.caption,\n      access_token: accessToken\n    })\n  }\n);\n\nconst carouselResult = await carouselResponse.json();\n\nif (!carouselResult.id) {\n  return [{ json: { error: true, details: carouselResult, queue_id: data.queue_id, carousel_id: data.carousel_id } }];\n}\n\n// Publish\nconst publishResponse = await fetch(\n  `https://graph.facebook.com/v19.0/${igUserId}/media_publish`,\n  {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({\n      creation_id: carouselResult.id,\n      access_token: accessToken\n    })\n  }\n);\n\nconst publishResult = await publishResponse.json();\n\nreturn [{\n  json: {\n    success: !!publishResult.id,\n    meta_post_id: publishResult.id || null,\n    queue_id: data.queue_id,\n    carousel_id: data.carousel_id,\n    error: publishResult.error || null\n  }\n}];"
      },
      "id": "meta-publish",
      "name": "Publicar Meta Graph API",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 100]
    },
