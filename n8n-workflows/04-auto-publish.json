        "url": "={{ $env.SUPABASE_URL }}/rest/v1/publish_queue?status=eq.queued&scheduled_for=lte.{{ $json.now }}&select=*,carousels(id,tenant_id,slides_json,caption,hashtags,meta_post_id)&order=scheduled_for",
        "options": {
