      "id": "get-queue",
      "name": "GET Publish Queue",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const queue = $input.first().json;\nif (!Array.isArray(queue) || queue.length === 0) {\n  return [{ json: { skip: true } }];\n}\nreturn queue.map(q => ({ json: q }));"
      },
      "id": "check-empty",
      "name": "Filtrar Vazios",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
